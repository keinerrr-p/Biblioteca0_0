@model Biblioteca0_0.Models.Devolucion

<h2>Registrar Devolución</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-controller="Devolucion" asp-action="register" method="post">

            <div class="form-group mb-3">
                <label>Préstamo</label>
                <select name="Idprestamo" class="form-control">
                    <option value="">-- Seleccione un préstamo --</option>
                    @foreach (var p in ViewBag.ListaPrestamos)
                    {
                        <option value="@p.Idprestamo">@p.Idprestamo - @p.IdlibroNavigation?.Titulo - @p.IdusuarioNavigation?.Nombre</option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Estado</label>
                <input name="Estado" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Multa</label>
                <input name="Multa" class="form-control" />
            </div>

            <div class="form-group mb-3">
                <label>Monto</label>
                <input name="Monto" type="number" step="0.01" class="form-control" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar Devolución</button>
            </div>
        </form>
    </div>
</div>

<hr />
<h3>Devoluciones</h3>
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Préstamo</th>
            <th>Libro</th>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var d in ViewBag.ListaDevoluciones)
        {
            <tr>
                <td>@d.Iddevo</td>
                <td>@d.Idprestamo</td>
                <td>@d.IdprestamoNavigation?.IdlibroNavigation?.Titulo</td>
                <td>@d.IdprestamoNavigation?.IdusuarioNavigation?.Nombre</td>
                <td>@d.Fechadevo</td>
                <td>
                    <a asp-action="Buscar" asp-route-id="@d.Iddevo" class="btn btn-info">Ver</a>
                    <a asp-action="Editar" asp-route-id="@d.Iddevo" class="btn btn-warning">Editar</a>
                    <form asp-action="Eliminar" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@d.Iddevo" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Eliminar devolucion?');">Borrar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>
