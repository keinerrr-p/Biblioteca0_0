@model Biblioteca0_0.Models.Prestamo

@{
    ViewData["Title"] = "Registrar Préstamo";
}

<h2>Registrar Préstamo</h2>

<div class="row">
    <div class="col-md-6">
        <form asp-controller="Prestamo" asp-action="register" method="post">

            <div class="form-group mb-3">
                <label>Libro</label>
                <select name="Idlibro" class="form-control">
                    <option value="">-- Seleccione un libro --</option>
                    @foreach (var libro in ViewBag.ListaLibros)
                    {
                        <option value="@libro.Idlibro">@libro.Titulo</option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Usuario</label>
                <select name="Idusuario" class="form-control">
                    <option value="">-- Seleccione un usuario --</option>
                    @foreach (var u in ViewBag.ListaUsuarios)
                    {
                        <option value="@u.Idusuario">@u.Nombre</option>
                    }
                </select>
            </div>

            <div class="form-group mb-3">
                <label>Estado</label>
                <input name="Estado" class="form-control" />
            </div>

            <div class="form-group">
                <button type="submit" class="btn btn-primary">Guardar Préstamo</button>
            </div>
        </form>
    </div>
</div>

<hr />
<h3>Préstamos</h3>
<table class="table">
    <thead>
        <tr>
            <th>ID</th>
            <th>Libro</th>
            <th>Usuario</th>
            <th>Fecha</th>
            <th>Acciones</th>
        </tr>
    </thead>
    <tbody>
        @foreach (var p in ViewBag.ListaPrestamos)
        {
            <tr>
                <td>@p.Idprestamo</td>
                <td>@(p.IdlibroNavigation?.Titulo)</td>
                <td>@(p.IdusuarioNavigation?.Nombre)</td>
                <td>@p.Fecha</td>
                <td>
                    <a asp-action="Buscar" asp-route-id="@p.Idprestamo" class="btn btn-info">Ver</a>
                    <a asp-action="Editar" asp-route-id="@p.Idprestamo" class="btn btn-warning">Editar</a>
                    <form asp-action="Eliminar" method="post" style="display:inline;">
                        <input type="hidden" name="id" value="@p.Idprestamo" />
                        <button type="submit" class="btn btn-danger" onclick="return confirm('Eliminar préstamo?');">Borrar</button>
                    </form>
                </td>
            </tr>
        }
    </tbody>
</table>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
